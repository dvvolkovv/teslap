# TeslaPay Backend — Environment Variable Reference
# Copy this file to .env and fill in real values for local development.
# NEVER commit a .env file with real secrets to version control.

# ---------------------------------------------------------------------------
# Service identity
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=info
PORT=8080

# ---------------------------------------------------------------------------
# PostgreSQL — full DSN including sslmode
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://teslapay:teslapay@localhost:5432/teslapay?sslmode=disable

# ---------------------------------------------------------------------------
# Redis — host:port ONLY (no redis:// scheme — see internal/common/config.go)
# ---------------------------------------------------------------------------
REDIS_URL=localhost:6379
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Kafka — comma-separated list of broker addresses
# ---------------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092

# ---------------------------------------------------------------------------
# JWT — RSA key file paths
# Generate with:
#   openssl genrsa -out keys/private.pem 4096
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
# ---------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ISSUER=teslapay.eu

# ---------------------------------------------------------------------------
# Token lifetimes (Go duration strings)
# ---------------------------------------------------------------------------
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# ---------------------------------------------------------------------------
# OpenTelemetry tracing (optional)
# ---------------------------------------------------------------------------
TRACE_ENDPOINT=
TRACE_SAMPLING=0.1
